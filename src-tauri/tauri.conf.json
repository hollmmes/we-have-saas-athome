{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "We Have SaaS at Home",
  "version": "0.6.0",
  "identifier": "com.hollmmes.we-have-saas-athome",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "We Have SaaS at Home by hollmmes",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["ffmpeg/ffmpeg.exe", "ffmpeg/ffprobe.exe"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/hollmmes/we-have-saas-athome/main/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwREFDNUQ5Njc0ODU1REIKUldUYlZVaG4yY1hhY0lMU05qY1I4aDgrMG0yampHV0oxRVpCM3BTUC9zbExWd2VLK0UzSE1XcVoK"
    },
    "sql": {
      "scope": {
        "allowed": [{ "path": "$APPDATA/images.db" }]
      }
    }
  }
}
